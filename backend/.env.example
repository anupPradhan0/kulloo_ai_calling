NODE_ENV=development
# Logging: debug|info|warn|error (default info in production, debug in development)
# LOG_LEVEL=info
# production logs are JSON lines unless LOG_FORMAT=pretty
# LOG_FORMAT=pretty
PORT=5000

# Redis (required): the API exits on startup if REDIS_URL is missing or Redis does not PING.
# Local: redis://localhost:6379  |  Docker Compose API service: redis://redis:6379
REDIS_URL=redis://localhost:6379
# REDIS_KEY_PREFIX=kulloo:
# REDIS_IDEMPOTENCY_TTL_SEC=86400
# REDIS_WEBHOOK_DEDUPE_TTL_SEC=172800
# Local dev: localhost. Docker/Dokploy: use Mongo service hostname or host IP — never localhost unless Mongo runs in that same container.
MONGODB_URI=mongodb://localhost:27017/sip-backend
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_ANSWER_URL=
PLIVO_HANGUP_URL=
# Public base for recording links, callbacks (match your server or reverse proxy)
PUBLIC_BASE_URL=http://app.anuppradhan.in

# ---- SIP Routing ----
# Kamailio load balancer (preferred in multi-FreeSWITCH deployments):
# Format: sip:1000@<kamailio-public-ip-or-host>  (port 5060 default)
# Plivo will send SIP INVITEs here; Kamailio distributes to fs1/fs2 pool.
# KullooCallId SIP header is forwarded untouched by Kamailio.
KAMAILIO_SIP_URI=sip:1000@187.127.150.91:5060
# Hostname/IP of Kamailio (used for logging/health checks, separate from URI)
KAMAILIO_HOST=187.127.150.91

# Direct FreeSWITCH SIP URI (fallback — used only if KAMAILIO_SIP_URI is not set):
# Use this for single-FS deployments or local dev without Kamailio.
FREESWITCH_SIP_URI=
# Comma-separated list of FreeSWITCH instances for health monitoring (optional):
# Example: fs1:5070,fs2:5071
FREESWITCH_INSTANCES=fs1:5070,fs2:5071

# Production recommended:
# - backend container mounts the same volume as FreeSWITCH at /recordings
RECORDINGS_DIR=/recordings

# FreeSWITCH ESL Configuration
# Host where FreeSWITCH is running (use container name in Docker, localhost for local dev)
FREESWITCH_ESL_HOST=localhost
# ESL port (default: 8021)
FREESWITCH_ESL_PORT=8021
# ESL password (default: ClueCon)
FREESWITCH_ESL_PASSWORD=ClueCon
# Port for ESL outbound server (FreeSWITCH connects TO this port)
ESL_OUTBOUND_PORT=3200

ORPHAN_GRACE_MS=120000
ORPHAN_SWEEP_INTERVAL_MS=60000

# ---- Flow B: Drachtio SIP Signaling (opt-in) ----
# Default is CALL_CONTROL_BACKEND=kulloo (Flow A: Kamailio + FreeSWITCH + ESL).
# Set to "drachtio" to activate Flow B: Drachtio C++ server + FreeSWITCH + ESL.
# See doc/drachtio.md for the full architecture.
#
# CALL_CONTROL_BACKEND=kulloo

# -- Only required when CALL_CONTROL_BACKEND=drachtio --

# Host of the drachtio C++ server container (Docker service name or IP).
# Node.js srf.connect() attaches to this host via the COMMAND port (not SIP port).
# DRACHTIO_HOST=drachtio

# Command port — the drachtio C++ server control plane (NOT the SIP port!).
# Plivo sends SIP INVITEs to drachtio on the SIP port (5060, set in docker-compose).
# Node.js connects to drachtio on this command port to receive INVITE notifications.
# DRACHTIO_PORT=9022

# Shared secret between the drachtio C++ server and this Node.js app.
# Must match the DRACHTIO_SECRET env var in the drachtio container.
# DRACHTIO_SECRET=kulloo-drachtio-secret

# SIP port on the drachtio container where Plivo/carrier sends INVITEs.
# Used for logging/documentation only; actual port mapping is in docker-compose.drachtio.yml.
# DRACHTIO_SIP_PORT=5060

# When Flow B is active, set FREESWITCH_SIP_URI to point directly at FreeSWITCH.
# (In Flow A, KAMAILIO_SIP_URI is used; in Flow B, Drachtio proxies directly to FS.)
# FREESWITCH_SIP_URI=sip:1000@<freeswitch-host>:5070

# ---- AI voice pipeline (AGENT_MODE=ai_voice) ----
# Default AGENT_MODE is "hello". Set to "ai_voice" for Deepgram → OpenAI → VEXYL-TTS (see doc/ai-voice-agent.md; roadmap .cursor/plans/ai-voice-pipeline.md).
# AGENT_MODE=ai_voice
# DEEPGRAM_API_KEY=
# OPENAI_API_KEY=
# AI_LLM_MODEL=gpt-4o-mini
# AI_VOICE_PERSONA=default
# AI_HISTORY_MAX_TURNS=10
# AI_SUMMARY_ON_HANGUP=true
# VEXYL_TTS_WS_URL=ws://vexyl-tts:8080
# VEXYL_TTS_API_KEY=
# VEXYL_TTS_LANG=en-IN
# VEXYL_TTS_STYLE=default
# AI_AUDIO_FORK_SAMPLE_RATE=8000
# AI_PLAYBACK_SAMPLE_RATE=8000
# AI_VOICE_USER_SLICE_MS=7000
# AI_VOICE_MAX_ROUNDS=20