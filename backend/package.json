{
  "name": "sip-backend",
  "version": "1.0.0",
  "description": "Backend setup with TypeScript, Node.js, Express.js, and MongoDB",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "verify:hello": "ts-node scripts/repeat-hello-calls.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1026.0",
    "@aws-sdk/s3-request-presigner": "^3.1026.0",
