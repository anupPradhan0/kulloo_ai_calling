    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drachtio-fsmrf": "^4.1.2",
    "drachtio-srf": "^5.0.20",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "modesl": "^1.1.8",
    "mongoose": "^8.13.2",
    "morgan": "^1.10.0",
    "plivo": "^4.75.8",
    "twilio": "^5.13.1",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.7",
    "@types/ws": "^8.5.14",
