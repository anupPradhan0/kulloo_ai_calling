<include>
  <!--
    freeswitch.xml — Main FreeSWITCH configuration for Kulloo
    
    Multi-instance notes:
    - SIP port is 5070 (NOT 5060) — Kamailio owns 5060 and proxies INVITEs here
    - Each FreeSWITCH instance (fs1, fs2, ...) listens on the SAME container-internal port (5070)
      but different HOST ports are mapped in docker-compose (5070, 5071, ...)
    - Context is "mrf" — this is where hello.xml defines the hello-call extension
      (was "public" which caused the extension to never fire; fixed here)
    - RTP range and external IP come from vars.fsN.xml (per-instance override)
    
    ESL (Event Socket) notes:
    - FreeSWITCH listens on 8021 (classic inbound ESL) — optional, kept for tooling
    - The hello flow uses OUTBOUND socket: FS connects TO Kulloo API on ESL_OUTBOUND_PORT (3200)
      This is configured in dialplan/hello.xml via $${kulloo_esl_host}:$${kulloo_esl_port}
  -->

  <configuration name="modules.conf" description="Modules">
    <modules>
      <load module="mod_console"/>
      <load module="mod_logfile"/>
      <load module="mod_sofia"/>
      <load module="mod_loopback"/>
      <load module="mod_commands"/>
      <load module="mod_dptools"/>
      <load module="mod_dialplan_xml"/>
      <load module="mod_xml_curl"/>
      <load module="mod_curl"/>
      <load module="mod_event_socket"/>
      <load module="mod_sndfile"/>
      <load module="mod_tone_stream"/>
      <load module="mod_native_file"/>
      <load module="mod_hash"/>
    </modules>
  </configuration>

  <!--
    Event Socket (classic inbound) — FreeSWITCH listens for tools/clients connecting TO it.
    This is SEPARATE from the outbound socket used by the hello flow.
    Outbound socket: FreeSWITCH connects OUT to Kulloo API on ESL_OUTBOUND_PORT.
  -->
  <configuration name="event_socket.conf" description="Event Socket">
    <settings>
      <param name="listen-ip" value="0.0.0.0"/>
      <param name="listen-port" value="8021"/>
      <param name="password" value="ClueCon"/>
    </settings>
  </configuration>

  <!--
    Switch core settings — session limits protect the server under load.
    600 max sessions @ 60/sec allows bursts while preventing runaway memory usage.
    Tune these per instance based on available CPU/RAM.
  -->
  <configuration name="switch.conf" description="Core Configuration">
    <settings>
      <!-- Max concurrent calls this instance will handle (500 streams = 500 calls) -->
      <param name="max-sessions" value="600"/>
      <!-- Max new sessions accepted per second (rate limiting) -->
      <param name="sessions-per-second" value="60"/>
      <!-- Minimum RTP port (overridden per-instance via vars.fsN.xml) -->
      <param name="rtp-start-port" value="$${rtp_start_port}"/>
      <!-- Maximum RTP port (overridden per-instance via vars.fsN.xml) -->
      <param name="rtp-end-port" value="$${rtp_end_port}"/>
    </settings>
  </configuration>

  <configuration name="sofia.conf" description="Sofia SIP">
    <global_settings>
      <param name="log-level" value="0"/>
      <param name="debug-presence" value="0"/>
    </global_settings>
    <profiles>
      <!--
        SIP profile "internal" — receives INVITEs forwarded by Kamailio.
        
        Key settings:
        - sip-port: 5070 (NOT 5060; Kamailio owns 5060)
        - context: mrf (where hello.xml lives; was "public" which broke routing)
        - auth-calls: false (Kamailio/Plivo sends unauthenticated INVITEs)
        - ext-sip-ip/ext-rtp-ip: public IP from vars.fsN.xml (CRITICAL for SDP correctness)
      -->
      <profile name="internal">
        <settings>
          <param name="sip-ip" value="0.0.0.0"/>
          <param name="rtp-ip" value="0.0.0.0"/>
          <!-- Public IP advertised in SIP Contact — comes from vars.fsN.xml -->
          <param name="ext-sip-ip" value="$${external_sip_ip}"/>
          <!-- Public IP advertised in SDP for RTP — MUST be correct for audio to work -->
          <param name="ext-rtp-ip" value="$${external_sip_ip}"/>
          <!-- FreeSWITCH SIP port — Kamailio proxies to this, NOT directly exposed to Plivo -->
          <param name="sip-port" value="5070"/>
          <!--
            Context MUST be "mrf" — hello.xml defines extensions under <context name="mrf">.
            If this is "public", all calls fall through to FreeSWITCH defaults and never
            reach the hello-call extension that sockets to Kulloo ESL.
          -->
          <param name="context" value="mrf"/>
          <param name="dialplan" value="XML"/>
          <param name="disable-transcoding" value="false"/>
          <!-- No auth — Kamailio / Plivo sends plain INVITEs -->
          <param name="auth-calls" value="false"/>
        </settings>
      </profile>
    </profiles>
  </configuration>

  <configuration name="dialplan.conf" description="Dialplan">
    <settings>
      <param name="db_dialplan" value="false"/>
    </settings>
  </configuration>

  <dialplan>
    <include>
      <!-- hello.xml defines the hello-call extension under context="mrf" -->
      <X-PRE-PROCESS cmd="include" data="dialplan/hello.xml"/>
    </include>
  </dialplan>
</include>
