<include>
  <context name="mrf">
    <extension name="hello-call">
      <condition field="destination_number" expression="^(1000|hello)$">
        <!-- Connect to Kulloo backend via ESL outbound socket for full programmatic control -->
        <action application="socket" data="host.docker.internal:3200 async full"/>
      </condition>
    </extension>
  </context>
</include>
