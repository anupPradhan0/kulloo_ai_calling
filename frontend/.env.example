# API origin (no trailing slash). Production:
VITE_API_BASE_URL=https://kulloocall.anuppradhan.in
#
# Local backend only — comment out the line above and use e.g.:
# VITE_API_BASE_URL=http://127.0.0.1:5000
#
# Same-origin only (empty base) — rarely needed if VITE_API_BASE_URL is set:
# VITE_USE_RELATIVE_API=true
