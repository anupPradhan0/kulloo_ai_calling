# --- Production (Docker + nginx on https://kulloocall...): use same-origin API ---
# No VITE_API_BASE_URL needed — requests go to /api on the UI host (nginx proxies to the API).
VITE_USE_RELATIVE_API=true
#
# --- Local dev: talk to a backend on another origin ---
# VITE_USE_RELATIVE_API=false
# VITE_API_BASE_URL=http://127.0.0.1:5000
#
# --- Separate API hostname (only with a valid TLS cert for that host) ---
# VITE_USE_RELATIVE_API=false
# VITE_API_BASE_URL=https://kulloocall.anuppradhan.in
