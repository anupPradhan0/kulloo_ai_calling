# API origin (no trailing slash). Backend host — production:
# UI is https://kulloocall.anuppradhan.in ; API is http://app.anuppradhan.in
# If the browser blocks mixed content (HTTPS page → HTTP API), use HTTPS on app or VITE_USE_RELATIVE_API=true with nginx proxy on kulloocall.
VITE_API_BASE_URL=http://app.anuppradhan.in
#
# Local backend only — comment out the line above and use e.g.:
# VITE_API_BASE_URL=http://127.0.0.1:5000
#
# Same-origin only (empty base) — rarely needed if VITE_API_BASE_URL is set:
# VITE_USE_RELATIVE_API=true
